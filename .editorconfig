root = true

[*]
charset = utf-8
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true

[*.{js,ts,vue,json,css,scss,md,yaml,yml}]
indent_style = space
indent_size = 2

[*.cs]
indent_style = space
indent_size = 4

[*.{csproj,slnx,props,targets}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
