POSTGRES_DB=hydraforge
POSTGRES_USER=hydraforge
POSTGRES_PASSWORD=change-this-postgres-password
# Host-side port — mapped to container 5432. Using 5433 to avoid conflict with any
# local PostgreSQL or Odysseus (which runs on the same machine).
POSTGRES_PORT=5433

ASPNETCORE_ENVIRONMENT=Development
# Container-internal port — host mapping is 5000:8080 (see docker-compose.yml).
# 8080 is taken by Odysseus SearXNG on the host.
ASPNETCORE_URLS=http://+:8080
ConnectionStrings__Default=Host=localhost;Port=5433;Database=hydraforge;Username=hydraforge;Password=change-this-postgres-password

# File storage (Local or S3)
FILE_STORAGE_PROVIDER=Local
FileStorage__Provider=Local
# Host-side local storage path. Docker Compose overrides this to
# /data/hydraforge/attachments and mounts a named volume there.
FileStorage__LocalPath=.hydraforge/attachments
FileStorage__MaxBytes=10485760
# S3-compatible (MinIO or AWS S3 — when FileStorage__Provider=S3):
# FileStorage__S3__BucketName=hydraforge-attachments
# FileStorage__S3__Region=us-east-1
# FileStorage__S3__AccessKey=minioadmin
# FileStorage__S3__SecretKey=minioadmin
# FileStorage__S3__Endpoint=http://localhost:9000
# FileStorage__S3__ForcePathStyle=true

# MinIO-specific (for docker compose — default creds, override via .env):
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=hydraforge-attachments
MINIO_REGION=us-east-1

Jwt__Issuer=HydraForge
Jwt__Audience=HydraForge
Jwt__SigningKey=change-this-to-at-least-32-random-characters
Jwt__AccessTokenMinutes=60

AdminSeed__Username=admin
AdminSeed__Password=change-this-admin-password

Argon2__MemorySizeKiB=65536
Argon2__Iterations=3
Argon2__Parallelism=4

Logging__MinimumLevel=Information
# Reuse Odysseus's SearXNG running on the host (127.0.0.1:8080).
# host.docker.internal resolves to the Docker host from inside a container.
# If running without Docker (dotnet run), change to http://localhost:8080.
# If running your own SearXNG via --profile search, change to http://searxng:8080.
SearXng__BaseUrl=http://host.docker.internal:8080

# ─── Web UI ───────────────────────────────────────────────────────────────────
# Private — Nuxt server-side proxy target for /api/... and SSR API calls.
# Docker Compose overrides this to http://server:8080 per docker-compose.yml.
NUXT_API_BASE_URL=http://localhost:5000

# SignalR hub base URL.
# Leave empty (default) in Docker — nginx routes /hubs/ directly to .NET with WS support.
# Set to http://localhost:5000 for local dev (dotnet run + pnpm dev) to enable
# direct WebSocket connection, eliminating WS errors in the browser console.
# NUXT_PUBLIC_SIGNALR_BASE_URL=http://localhost:5000

# CORS: comma-separated allowed origins for the .NET backend.
# Docker default (nginx port 80): http://localhost
# For Tailscale or a real domain, add your host: http://100.x.x.x,https://app.example.com
# CORS_ALLOWED_ORIGINS=http://localhost

# Auth cookie settings
NUXT_PUBLIC_AUTH_COOKIE_MAX_AGE=3600
NUXT_PUBLIC_AUTH_COOKIE_SECURE=false
