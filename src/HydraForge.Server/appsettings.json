{
  "ConnectionStrings": {
    "Default": "Host=localhost;Database=hydraforge;Username=postgres;Password=password"
  },
  "Database": {
    "ApplyMigrationsOnStartup": true
  },
  "FileStorage": {
    "Provider": "Local",
    "LocalPath": "/var/lib/hydraforge/attachments",
    "MaxBytes": 10485760
  },
  "Jwt": {
    "Issuer": "HydraForge",
    "Audience": "HydraForge",
    "SigningKey": "your-256-bit-secret-key-here-replace-in-production",
    "AccessTokenMinutes": 60
  },
  "AdminSeed": {
    "Username": null,
    "Password": null,
    "Name": null,
    "LastName": null,
    "Email": null
  },
  "Argon2": {
    "MemorySizeKiB": 65536,
    "Iterations": 3,
    "Parallelism": 4
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": "http://localhost:3000"
  }
}

