### Column API Smoke Tests
### Run against local development environment

@adminToken = {{loginAdmin.response.body.$.accessToken}}
@baseUrl = http://localhost:5000

# ── Auth ────────────────────────────────────────────────────

# @name loginAdmin

POST {{baseUrl}}/api/auth/login HTTP/1.1
Content-Type: application/json
X-Correlation-Id: smoke-test-col-001

{
  "password": "TestAdmin123!",
  "username": "testadmin"
}


###

# ── Column Operations ────────────────────────────────────────
# Create a project first so we have a valid projectId

# @name createProject

POST {{baseUrl}}/api/projects HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-col-002

{
  "description": "Project for column smoke test",
  "gitProvider": "github",
  "gitRemoteUrl": "https://github.com/test/test.git",
  "name": "Column Smoke Test Project"
}


###

# ── Columns ─────────────────────────────────────────────────
# Create first column - project already has 6 default columns (0-5),
# so this appends at position 6

# @name createColumn1

POST {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/columns HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-col-003

{
  "name": "Extra Column 1",
  "color": "#336699",
  "wipLimit": null
}


###
# Create second column (appends at position 7)

# @name createColumn2

POST {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/columns HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-col-004

{
  "name": "In Progress",
  "color": "#FF0000",
  "wipLimit": 5
}


###

# Create third column (appends at position 8)

# @name createColumn3

POST {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/columns HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-col-005

{
  "name": "Done",
  "color": "#00FF00",
  "wipLimit": null
}


###

# List all columns for project

GET {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/columns HTTP/1.1
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-col-006


###

# Get column by ID

GET {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/columns/{{createColumn1.response.body.$.id}} HTTP/1.1
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-col-007


###

# Update column

PUT {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/columns/{{createColumn1.response.body.$.id}} HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-col-008

{
  "name": "Backlog - Updated",
  "color": "#0000FF",
  "wipLimit": 10
}


###

# Reorder columns - valid IDs (reverse order)

# @name reorderColumns

PUT {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/columns/reorder HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-col-009

{
  "columnIds": [
    "{{createColumn3.response.body.$.id}}",
    "{{createColumn2.response.body.$.id}}",
    "{{createColumn1.response.body.$.id}}"
  ]
}


###

# Verify reorder worked - list columns again

GET {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/columns HTTP/1.1
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-col-010


###

# Reorder columns - invalid ID returns 400

PUT {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/columns/reorder HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-col-011

{
  "columnIds": [
    "{{createColumn1.response.body.$.id}}",
    "99999999-9999-9999-9999-999999999999"
  ]
}


###

# Reorder columns - wrong count returns 400

PUT {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/columns/reorder HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-col-012

{
  "columnIds": [
    "{{createColumn1.response.body.$.id}}"
  ]
}


###

# Delete empty column (column with no cards)

DELETE {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/columns/{{createColumn1.response.body.$.id}} HTTP/1.1
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-col-013


###

# Delete non-empty column returns 409
# First create a card in a column, then try to delete that column

# @name createCardInColumn

POST {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/cards HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-col-014

{
  "columnId": "{{createColumn2.response.body.$.id}}",
  "name": "Card in In Progress",
  "description": "This card prevents column deletion"
}


###

# Try to delete column that has cards - should return 409

DELETE {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/columns/{{createColumn2.response.body.$.id}} HTTP/1.1
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-col-015


###

# ── Non-member / Invalid ID Examples ────────────────────────
# Try to list columns as non-member user

POST {{baseUrl}}/api/auth/login HTTP/1.1
Content-Type: application/json
X-Correlation-Id: smoke-test-col-016

{
  "password": "NonMember123!",
  "username": "nonmember"
}


###

# Get column with invalid column ID (should return 404)

GET {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/columns/00000000-0000-0000-0000-000000000000 HTTP/1.1
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-col-017


###

# Update column with invalid column ID (should return 404)

PUT {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/columns/00000000-0000-0000-0000-000000000000 HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-col-018

{
  "name": "Updated Name",
  "color": "#FF0000",
  "wipLimit": 1
}


###

# Delete column with invalid column ID (should return 404)

DELETE {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/columns/00000000-0000-0000-0000-000000000000 HTTP/1.1
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-col-019


###

# List columns without auth (should return 401)

GET {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/columns HTTP/1.1
X-Correlation-Id: smoke-test-col-020


###

# ── Cleanup ─────────────────────────────────────────────────
# Archive the test project

DELETE {{baseUrl}}/api/projects/{{createProject.response.body.$.id}} HTTP/1.1
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-col-021