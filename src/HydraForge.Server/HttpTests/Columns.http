###

# ── Non-member / Invalid ID Examples ────────────────────────

POST {{baseUrl}}/api/auth/login HTTP/1.1
Content-Type: application/json
X-Correlation-Id: smoke-test-col-017

{
  "password": "NonMember123!",
  "username": "nonmember"
}


###

# Get column with invalid column ID (should return 404)

GET {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/columns/00000000-0000-0000-0000-000000000000 HTTP/1.1
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-col-018


###

# Update column with invalid column ID (should return 404)

PUT {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/columns/00000000-0000-0000-0000-000000000000 HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-col-019

{
  "color": "#FF0000",
  "name": "Updated Name",
  "wipLimit": 1
}


###

# Delete column with invalid column ID (should return 404)

DELETE {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/columns/00000000-0000-0000-0000-000000000000 HTTP/1.1
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-col-020


###

# List columns without auth (should return 401)

GET {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/columns HTTP/1.1
X-Correlation-Id: smoke-test-col-021


###

# ── Cleanup ─────────────────────────────────────────────────

DELETE {{baseUrl}}/api/projects/{{createProject.response.body.$.id}} HTTP/1.1
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-col-022
