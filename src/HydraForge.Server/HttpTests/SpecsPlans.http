###

# ── List Plan Versions ──────────────────────────────────────

# @name listPlanVersions

GET {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/plans/{{createPlan.response.body.$.id}}/versions HTTP/1.1
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-specplan-018


###

# ── Restore Plan to v1 ──────────────────────────────────────

# @name restorePlan

POST {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/plans/{{createPlan.response.body.$.id}}/restore HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-specplan-019

{
  "version": 1
}


###

# ── Link Plan to Card ───────────────────────────────────────

# @name linkPlanToCard

POST {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/plans/{{createPlan.response.body.$.id}}/link HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-specplan-020

{
  "cardId": "{{createCard.response.body.$.id}}"
}


###

# ── Verify Plan Linked Card ID ──────────────────────────────

# @name getPlanAfterLink

GET {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/plans/{{createPlan.response.body.$.id}} HTTP/1.1
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-specplan-021


###

# ── Unlink Plan from Card ────────────────────────────────────

DELETE {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/plans/{{createPlan.response.body.$.id}}/link?cardId={{createCard.response.body.$.id}} HTTP/1.1
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-specplan-022


###

# ── Cleanup ─────────────────────────────────────────────────

DELETE {{baseUrl}}/api/projects/{{createProject.response.body.$.id}} HTTP/1.1
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-specplan-023
