### Attachment API Smoke Tests
### Run against local development environment

@adminToken = {{loginAdmin.response.body.$.accessToken}}
@baseUrl = http://localhost:5000

# ── Auth ────────────────────────────────────────────────────

# @name loginAdmin

POST {{baseUrl}}/api/auth/login HTTP/1.1
Content-Type: application/json
X-Correlation-Id: smoke-test-att-001

{
  "password": "TestAdmin123!",
  "username": "testadmin"
}


###

# ── Project Setup ───────────────────────────────────────────

# @name createProject

POST {{baseUrl}}/api/projects HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-att-002

{
  "description": "Project for attachment smoke test",
  "gitProvider": "github",
  "gitRemoteUrl": "https://github.com/test/test.git",
  "name": "Attachment Smoke Test Project"
}


###

# List columns to get default column IDs

# @name listColumns

GET {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/columns HTTP/1.1
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-att-003


###

# ── Create Card ──────────────────────────────────────────────

# @name createCard

POST {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/cards HTTP/1.1
Content-Type: application/json
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-att-004

{
  "columnId": "{{listColumns.response.body.$[0].id}}",
  "description": "Card with attachments for smoke test",
  "title": "Attachment Test Card",
  "type": "Task"
}


###

# ── Upload text/plain attachment ─────────────────────────────

# @name uploadText

POST {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/cards/{{createCard.response.body.$.id}}/attachments HTTP/1.1
Authorization: Bearer {{adminToken}}
Content-Type: multipart/form-data; boundary=attachment-boundary
X-Correlation-Id: smoke-test-att-005

--attachment-boundary
Content-Disposition: form-data; name="file"; filename="readme.txt"
Content-Type: text/plain

Hello, this is a test attachment file for the HydraForge smoke test.
--attachment-boundary--


###

# ── Upload application/json attachment ───────────────────────

POST {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/cards/{{createCard.response.body.$.id}}/attachments HTTP/1.1
Authorization: Bearer {{adminToken}}
Content-Type: multipart/form-data; boundary=attachment-boundary
X-Correlation-Id: smoke-test-att-006

--attachment-boundary
Content-Disposition: form-data; name="file"; filename="data.json"
Content-Type: application/json

{"name": "test", "version": 1}
--attachment-boundary--


###

# ── List attachments ────────────────────────────────────────

# @name listAttachments

GET {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/cards/{{createCard.response.body.$.id}}/attachments HTTP/1.1
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-att-007


###

# ── Download first attachment ────────────────────────────────

GET {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/cards/{{createCard.response.body.$.id}}/attachments/{{listAttachments.response.body.$.attachments[0].id}} HTTP/1.1
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-att-008


###

# ── Download second attachment ───────────────────────────────

GET {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/cards/{{createCard.response.body.$.id}}/attachments/{{listAttachments.response.body.$.attachments[1].id}} HTTP/1.1
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-att-009


###

# ── Delete second attachment ────────────────────────────────

DELETE {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/cards/{{createCard.response.body.$.id}}/attachments/{{listAttachments.response.body.$.attachments[1].id}} HTTP/1.1
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-att-010


###

# ── Verify deletion (list should return 1 attachment) ────────

GET {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/cards/{{createCard.response.body.$.id}}/attachments HTTP/1.1
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-att-011


###

# ── Upload unsupported content type (expect 415) ─────────────

POST {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/cards/{{createCard.response.body.$.id}}/attachments HTTP/1.1
Authorization: Bearer {{adminToken}}
Content-Type: multipart/form-data; boundary=attachment-boundary
X-Correlation-Id: smoke-test-att-012

--attachment-boundary
Content-Disposition: form-data; name="file"; filename="malware.exe"
Content-Type: application/x-msdownload

fake exe content
--attachment-boundary--


###

# ── Upload file exceeding size limit (expect 413) ───────────
# NOTE: Requires a file larger than FileStorage:MaxBytes (10 MB).
# Generate one with: dd if=/dev/zero of=./large.bin bs=1M count=12

POST {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/cards/{{createCard.response.body.$.id}}/attachments HTTP/1.1
Authorization: Bearer {{adminToken}}
Content-Type: multipart/form-data; boundary=attachment-boundary
X-Correlation-Id: smoke-test-att-013

--attachment-boundary
Content-Disposition: form-data; name="file"; filename="large.bin"
Content-Type: application/octet-stream

< ./testdata/large.bin
--attachment-boundary--


###

# ── Download non-existent attachment (expect 404) ────────────

GET {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/cards/{{createCard.response.body.$.id}}/attachments/00000000-0000-0000-0000-000000000000 HTTP/1.1
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-att-014


###

# ── Upload without auth (expect 401) ─────────────────────────

POST {{baseUrl}}/api/projects/{{createProject.response.body.$.id}}/cards/{{createCard.response.body.$.id}}/attachments HTTP/1.1
Content-Type: multipart/form-data; boundary=attachment-boundary
X-Correlation-Id: smoke-test-att-015

--attachment-boundary
Content-Disposition: form-data; name="file"; filename="test.txt"
Content-Type: text/plain

no auth
--attachment-boundary--


###

# ── Cleanup ─────────────────────────────────────────────────

DELETE {{baseUrl}}/api/projects/{{createProject.response.body.$.id}} HTTP/1.1
Authorization: Bearer {{adminToken}}
X-Correlation-Id: smoke-test-att-016
