# HydraForge Web UI — Environment Variables
# Copy this file to .env and fill in values for local development.
# In production/Docker, set these as environment variables.

# Backend API base URL
NUXT_PUBLIC_API_BASE_URL=http://localhost:5000

# Auth cookie settings (in seconds)
NUXT_PUBLIC_AUTH_COOKIE_MAX_AGE=3600

# Set to 'true' in production (HTTPS only)
NUXT_PUBLIC_AUTH_COOKIE_SECURE=false
